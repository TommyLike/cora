# cora local development environment variables
# Copy to .env and fill in your values.
# .env is loaded automatically at startup (local dev only).
# Real environment variables always take precedence over .env values.

# --- Config file path ---
# Override the default config file location (~/.config/cora/config.yaml).
# CORA_CONFIG=/path/to/custom/config.yaml

# --- Spec cache ---
# CORA_SPEC_CACHE_TTL=24h
# CORA_SPEC_CACHE_DIR=~/.config/cora/cache

# --- Per-service overrides ---
# Replace FORUM with your service name in uppercase.
# These override the corresponding values in config.yaml.
#
# CORA_SERVICES_FORUM_BASE_URL=http://localhost:3000
# CORA_SERVICES_FORUM_SPEC_URL=assets/openapi/forum/openapi.json
# CORA_SERVICES_FORUM_AUTH_DISCOURSE_API_KEY=your-dev-api-key
# CORA_SERVICES_FORUM_AUTH_DISCOURSE_API_USERNAME=system
